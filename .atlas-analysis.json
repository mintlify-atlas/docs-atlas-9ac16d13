  "keyFeatures": [
    "OpenAI/Gemini/Claude/Codex compatible API endpoints",
    "Multi-provider OAuth authentication (Gemini, Claude, OpenAI, Qwen, iFlow, Antigravity)",
    "Multi-account load balancing with round-robin and fill-first strategies",
    "Model aliasing and custom mappings",
    "Streaming and non-streaming responses with function calling support",
    "Management API for runtime configuration and monitoring",
    "Reusable Go SDK for embedding the proxy",
    "Amp CLI integration with provider routing"
  ],
  "publicApiSurface": [
    "/v1/chat/completions - OpenAI-compatible chat endpoint",
    "/v1/models - List available models",
    "/v1/ws - WebSocket API for real-time streaming",
    "/v0/management/config - Get/update configuration",
    "/v0/management/oauth/callback - OAuth callback handler",
    "/v0/management/quota - Query quota information",
    "/v0/management/logs - Access server logs",
    "/api/provider/{provider}/v1/* - Amp CLI provider routes",
    "sdk/cliproxy.NewBuilder() - Go SDK entry point",
    "sdk/auth.Manager - Core authentication manager"
  ]
}
